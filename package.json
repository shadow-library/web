{
  "name": "@shadow-library/web",
  "version": "0.1.0",
  "type": "module",
  "description": "Frontend application framework for the Shadow Apps ecosystem — the typed API transport, TanStack Router/Query wiring, SSR session plumbing, and the Bun production server that every Shadow web app shares.",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "type-check": "tsc",
    "lint": "biome check",
    "format": "biome format --write",
    "prepublishOnly": "bun run build",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/shadow-library/web.git"
  },
  "author": "Leander Paul <leanderpaul97@outlook.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/shadow-library/web/issues"
  },
  "homepage": "https://github.com/shadow-library/web#readme",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./router": {
      "types": "./dist/router/index.d.ts",
      "default": "./dist/router/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "default": "./dist/server/index.js"
    },
    "./server-entry": {
      "types": "./dist/server-entry.d.ts",
      "default": "./dist/server-entry.js"
    },
    "./package.json": "./package.json"
  },
  "peerDependencies": {
    "@tanstack/react-query": "^5.100.0",
    "@tanstack/react-router": "^1.168.0",
    "@tanstack/react-router-ssr-query": "^1.167.0",
    "@tanstack/react-start": "^1.168.0",
    "react": "^18.3.0 || ^19.0.0",
    "typescript": "^5.7.0"
  },
  "peerDependenciesMeta": {
    "@tanstack/react-query": { "optional": true },
    "@tanstack/react-router": { "optional": true },
    "@tanstack/react-router-ssr-query": { "optional": true },
    "@tanstack/react-start": { "optional": true },
    "typescript": { "optional": true }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@release-it/conventional-changelog": "^10.0.6",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-router": "^1.170.17",
    "@tanstack/react-router-ssr-query": "^1.167.1",
    "@tanstack/react-start": "^1.168.27",
    "@types/bun": "^1.3.9",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "husky": "^9.1.7",
    "react": "^19.2.0",
    "release-it": "^19.2.4",
    "typescript": "^5.7.2"
  }
}
